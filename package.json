{
  "name": "root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@types/node": "^24.13.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^9.39.1",
    "@eslint/json": "^0.14.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lerna": "^9.0.7",
    "lint-staged": "^16.4.0",
    "npm-check-updates": "^19.6.6",
    "oxlint": "^1.72.0",
    "prettier": "^3.9.4",
    "release-it": "^20.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1"
  },
  "overrides": {
    "js-yaml": "^4.3.0",
    "tar": "^7.5.16"
  },
  "scripts": {
    "dev": "npx lerna run storybook:start --scope=@orchestra-design-system/storybook",
    "build": "npm run build:tokens && npx lerna run build",
    "build:tokens": "npx lerna run build --scope='@orchestra-design-system/themes'",
    "build:storybook": "npx lerna run build-storybook --scope=@orchestra-design-system/storybook",
    "update": "npx npm-check-updates -u",
    "format": "npx prettier . --write",
    "lint": "npx oxlint . --fix --import-plugin --vitest-plugin --jest-plugin --node-plugin --vue-plugin",
    "lint:check": "npx oxlint . --import-plugin --vitest-plugin --jest-plugin --node-plugin --vue-plugin",
    "lint:eslint": "npx eslint --no-ignore eslint.config.mjs commitlint.config.cjs",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "commitlint": "commitlint --edit",
    "test": "npx lerna run storybook:test --scope=@orchestra-design-system/storybook",
    "test:coverage": "npx lerna run storybook:test-coverage --scope=@orchestra-design-system/storybook",
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "release:core": "cd packages/core && release-it",
    "release:core:dry": "cd packages/core && release-it --dry-run",
    "release:react": "cd packages/react && release-it",
    "release:react:dry": "cd packages/react && release-it --dry-run",
    "release:angular": "cd packages/angular && release-it",
    "release:angular:dry": "cd packages/angular && release-it --dry-run",
    "release:vue": "cd packages/vue && release-it",
    "release:vue:dry": "cd packages/vue && release-it --dry-run",
    "release:themes": "cd packages/themes && release-it",
    "release:themes:dry": "cd packages/themes && release-it --dry-run",
    "release:icons-library": "cd packages/icons-library && release-it",
    "release:icons-library:dry": "cd packages/icons-library && release-it --dry-run"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --fix --no-error-on-unmatched-pattern --import-plugin --vitest-plugin --jest-plugin --node-plugin --vue-plugin",
      "prettier --write"
    ],
    "*.{json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  },
  "version": "0.0.1"
}
