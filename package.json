{
  "name": "orchestra-kit",
  "version": "1.0.0",
  "description": "Orchestra kit is a library of components that follows Orchestra Design Systems principles to help building web interfaces with React.",
  "main": "dist/cjs/index.js",
  "module": "dist/index.js",
  "typings": "dist/index.d.ts",
  "scripts": {
    "build": "npm run rollup && npm run post:build",
    "post:build": "node ./scripts/postBuild.js",
    "rollup": "rm -rf dist && rollup -c",
    "storybook": "start-storybook -p 6006 --no-manager-cache",
    "storybook:build": "build-storybook",
    "test": "jest",
    "test:coverage": "jest --coverage --collectCoverageFrom='./src/**'",
    "lint": "eslint --fix --ext .ts,.tsx"
  },
  "author": "Yann Isabel",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.18.10",
    "@emotion/react": "^11.10.0",
    "@emotion/styled": "^11.10.0",
    "@rollup/plugin-commonjs": "^21.0.2",
    "@rollup/plugin-node-resolve": "^13.1.3",
    "@rollup/plugin-replace": "^4.0.0",
    "@storybook/addon-actions": "^6.5.10",
    "@storybook/addon-essentials": "^6.5.10",
    "@storybook/addon-interactions": "^6.5.10",
    "@storybook/addon-links": "^6.5.10",
    "@storybook/builder-webpack5": "^6.5.10",
    "@storybook/manager-webpack5": "^6.5.10",
    "@storybook/preset-scss": "^1.0.3",
    "@storybook/react": "^6.5.10",
    "@storybook/testing-library": "^0.0.13",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/jest": "^29.1.1",
    "@types/node": "^18.7.3",
    "@types/react": "^18.0.17",
    "@types/react-dom": "^18.0.6",
    "@typescript-eslint/eslint-plugin": "^5.39.0",
    "@typescript-eslint/parser": "^5.39.0",
    "babel-loader": "^8.2.5",
    "eslint": "^8.25.0",
    "jest": "^29.1.2",
    "jest-environment-jsdom": "^29.1.2",
    "node-sass": "^7.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rollup": "^2.68.0",
    "rollup-plugin-copy": "^3.4.0",
    "rollup-plugin-generate-package-json": "^3.2.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-rename": "^1.0.1",
    "rollup-plugin-scss": "^2.6.1",
    "rollup-plugin-terser": "^7.0.2",
    "rollup-plugin-typescript2": "^0.31.2",
    "sass": "^1.54.4",
    "sass-loader": "^13.0.2",
    "ts-jest": "^29.0.3",
    "typescript": "^4.7.4",
    "webpack": "^5.74.0"
  },
  "peerDependencies": {
    "@emotion/react": "^11.10.0",
    "@emotion/styled": "^11.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}