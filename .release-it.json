{
  "git": {
    "commit": true,
    "commitMessage": "chore(release): ${version}",
    "tag": true,
    "tagName": "${name}@${version}",
    "push": true,
    "requireUpstream": false,
    "getLatestTagInBranch": true
  },
  "npm": {
    "publish": true,
    "allowSameVersion": false
  },
  "github": {
    "release": true,
    "releaseName": "${version}"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "inFile": "CHANGELOG.md"
    }
  },
  "hooks": {
    "before:init": [
      "npm run lint",
      "npm run build"
    ],
    "after:bumped": [
      "npm run format"
    ]
  }
}
