{
  "git": {
    "commit": true,
    "commitMessage": "chore(release): v${version}",
    "tag": true,
    "tagName": "v${version}",
    "push": true,
    "requireUpstream": false,
    "getLatestTagInBranch": true
  },
  "npm": {
    "publish": true,
    "publishPath": ".",
    "allowSameVersion": false
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "hooks": {
    "before:init": [
      "npm run lint",
      "npm run build"
    ],
    "after:bumped": [
      "npm run format"
    ]
  }
}
