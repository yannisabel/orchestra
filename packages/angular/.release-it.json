{
  "git": {
    "commit": true,
    "commitMessage": "chore(@orchestra-kit/angular): release v${version}",
    "tag": true,
    "tagName": "@orchestra-kit/angular@${version}",
    "push": true,
    "requireUpstream": false
  },
  "npm": {
    "publish": true,
    "publishArgs": ["--access", "public"],
    "allowSameVersion": false
  },
  "github": {
    "release": true,
    "releaseName": "@orchestra-kit/angular v${version}"
  }
}
