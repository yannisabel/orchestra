{
  "git": {
    "commit": true,
    "commitMessage": "chore(@orchestra-design-system/angular): release v${version}",
    "tag": true,
    "tagName": "@orchestra-design-system/angular@${version}",
    "push": true,
    "requireUpstream": false
  },
  "npm": {
    "publish": true,
    "publishArgs": ["--access", "public"],
    "allowSameVersion": false
  },
  "github": {
    "release": true,
    "releaseName": "@orchestra-design-system/angular v${version}"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits",
      "infile": "CHANGELOG.md"
    }
  }
}
