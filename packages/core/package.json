{
  "name": "@orchestra-design-system/core",
  "type": "module",
  "version": "0.0.11",
  "description": "Web components for the Orchestra design system",
  "author": "Yann Isabel",
  "keywords": [
    "design-system",
    "web-components",
    "stencil",
    "orchestra"
  ],
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.js",
  "es2017": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/core/core.esm.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/index.cjs.js",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./loader/index.d.ts",
      "require": "./loader/index.cjs.js",
      "import": "./loader/index.js"
    },
    "./loader": {
      "types": "./loader/index.d.ts",
      "require": "./loader/index.cjs.js",
      "import": "./loader/index.js"
    },
    "./hydrate": {
      "types": "./hydrate/index.d.ts",
      "require": "./hydrate/index.cjs.js",
      "import": "./hydrate/index.mjs"
    },
    "./dist/components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./dist/components/index": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./dist/components/orchestra-button.js": {
      "types": "./dist/components/orchestra-button.d.ts",
      "import": "./dist/components/orchestra-button.js"
    },
    "./dist/components/orchestra-icon.js": {
      "types": "./dist/components/orchestra-icon.d.ts",
      "import": "./dist/components/orchestra-icon.js"
    },
    "./dist/components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./src/components/*/readme.md": "./src/components/*/readme.md",
    "./dist/esm/*": "./dist/esm/*",
    "./dist/orchestra-design-system/*": "./dist/orchestra-design-system/*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yannisabel/orchestra.git"
  },
  "files": [
    "dist/",
    "loader/",
    "hydrate/"
  ],
  "scripts": {
    "start": "npm run start:js",
    "start:js": "stencil build --docs --watch",
    "start:preview": "concurrently 'npm run preview' 'npm run start:js'",
    "build": "npm run build:js",
    "build:js": "stencil build --docs",
    "test": "stencil-test",
    "test:watch": "stencil-test --watch",
    "test:e2e": "stencil-test --project browser",
    "test:spec": "stencil-test --project spec",
    "generate": "stencil generate",
    "update": "npx npm-check-updates -u",
    "preview": "npx http-server www"
  },
  "dependencies": {
    "@orchestra-design-system/icons-library": "^0.0.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@stencil/angular-output-target": "^1.4.0",
    "@stencil/core": "^4.43.5",
    "@stencil/playwright": "^0.2.3",
    "@stencil/react-output-target": "^1.6.0",
    "@stencil/sass": "3.2.3",
    "@stencil/utils": "^0.0.5",
    "@stencil/vue-output-target": "^0.11.8",
    "@types/jest": "^30.0.0",
    "concurrently": "^9.2.3",
    "dompurify": "^3.4.11",
    "http-server": "^14.1.1",
    "jest": "^30.4.2",
    "jest-cli": "^30.4.2",
    "rollup-plugin-postcss": "^4.0.2",
    "vite": "^7.2.4"
  },
  "license": "MIT"
}
