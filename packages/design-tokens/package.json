{
  "name": "@orchestra-design-system/design-tokens",
  "type": "module",
  "version": "0.0.7",
  "description": "Design tokens for the Orchestra design system",
  "main": "sd.config.js",
  "scripts": {
    "start": "concurrently 'npm run watch' 'npm run watch:extended'",
    "watch": "tsx watch --exclude './tokens/gen-*.**' --include './tokens/*.**' sd.config.js",
    "watch:extended": "tsx watch --include './tokens/extended/tokens/*.**' ./tokens/extended/build.js",
    "build": "node sd.config.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.3",
    "json5": "^2.2.3",
    "lodash": "^4.18.1",
    "style-dictionary": "^5.5.0",
    "tsx": "^4.22.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yannisabel/orchestra.git"
  },
  "author": "Yann Isabel",
  "keywords": [
    "design-system",
    "design-tokens",
    "css-variables",
    "orchestra"
  ],
  "license": "MIT"
}
