{
  "name": "@orchestra-design-system/vue",
  "version": "0.0.13",
  "description": "Vue wrappers for Orchestra design system web components",
  "author": "Yann Isabel",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "lib",
    "dist"
  ],
  "scripts": {
    "build": "npm run tsc",
    "tsc": "tsc -p . --outDir ./dist"
  },
  "dependencies": {
    "@orchestra-design-system/core": "^0.0.13",
    "@stencil/vue-output-target": "^0.11.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yannisabel/orchestra.git"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vue": "^3.5.39"
  },
  "keywords": [
    "design-system",
    "vue",
    "web-components",
    "orchestra"
  ],
  "license": "MIT"
}
