{
  "name": "@orchestra-design-system/icons-library",
  "version": "0.0.12",
  "description": "Orchestra icon library - SVG icons for Orchestra components",
  "author": "Yann Isabel",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "svg"
  ],
  "scripts": {
    "build": "node generate-icons.mjs && tsc && node build.mjs",
    "build:watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "icon",
    "svg",
    "orchestra",
    "design-system"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yannisabel/orchestra.git"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
