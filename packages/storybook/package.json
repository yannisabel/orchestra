{
  "name": "@orchestra-design-system/storybook",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "storybook:dev": "storybook dev -p 6006",
    "storybook:start": "concurrently \"(cd ../core/ && npm start)\" \"npm run storybook:dev\"",
    "storybook:test": "vitest --project=storybook",
    "storybook:test-coverage": "vitest --project=storybook --coverage",
    "build-storybook": "storybook build",
    "build-storybook-ci": "BASE_PATH=/orchestra-kit/ storybook build",
    "preview-storybook": "npx http-server storybook-static",
    "update": "npx npm-check-updates -u"
  },
  "dependencies": {
    "@orchestra-design-system/core": "^0.0.1",
    "@orchestra-design-system/icons-library": "^0.0.1",
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@stencil/storybook-plugin": "^0.6.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-coverage": "^3.0.1",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-links": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/web-components-vite": "^10.4.6",
    "@testing-library/dom": "^10.4.1",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "@vueless/storybook-dark-mode": "^10.0.8",
    "concurrently": "^9.2.3",
    "eslint-plugin-storybook": "10.0.8",
    "http-server": "^14.1.1",
    "playwright": "^1.61.0",
    "shadow-dom-testing-library": "^1.14.0",
    "storybook": "^10.4.6",
    "vite": "^7.2.4",
    "vite-plugin-live-reload": "^3.1.0",
    "vitest": "^4.1.9"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.53.3"
  }
}
